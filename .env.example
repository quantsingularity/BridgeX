# BridgeX - Open Banking API Connector
# Copy to .env and fill in values. All defaults work out of the box.

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=bridgex
POSTGRES_PASSWORD=bridgex_secret
POSTGRES_DB=bridgex
DATABASE_URL=postgresql://bridgex:bridgex_secret@postgres:5432/bridgex

# Redis
REDIS_URL=redis://redis:6379/0

# App
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Encryption (AES-256 - must be exactly 32 characters)
ENCRYPTION_KEY=change-me-exactly-32-chars-long!!
ENCRYPTION_IV_LENGTH=16

# OAuth
OAUTH_CALLBACK_BASE_URL=http://localhost:4000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Webhooks
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_BACKOFF_MS=5000
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_SECRET_LENGTH=32

# Sandbox
SANDBOX_MODE=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
